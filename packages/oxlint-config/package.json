{
  "name": "@alleyinteractive/oxlint-config",
  "version": "0.1.0",
  "description": "Alley's custom Oxlint and Oxfmt shareable configuration with linting and formatting",
  "keywords": [
    "eslint",
    "formatter",
    "linter",
    "oxfmt",
    "oxlint",
    "react",
    "typescript"
  ],
  "homepage": "https://github.com/alleyinteractive/alley-scripts#readme",
  "bugs": {
    "url": "https://github.com/alleyinteractive/alley-scripts/issues"
  },
  "license": "GPL-2.0-or-later",
  "author": "Alley <info@alley.com> (https://alley.com)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alleyinteractive/alley-scripts.git"
  },
  "files": [
    "oxlint.config.ts",
    "oxfmt.config.ts",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": "./oxlint.config.ts",
    "./oxfmt": "./oxfmt.config.ts"
  },
  "scripts": {
    "format": "oxfmt -c oxfmt.config.ts .",
    "format:check": "oxfmt -c oxfmt.config.ts . --check",
    "lint": "oxlint -c oxlint.config.ts ."
  },
  "peerDependencies": {
    "oxfmt": "^0.43",
    "oxlint": "^1.52",
    "oxlint-plugin-eslint": "^1.59"
  }
}
